rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Cada profe solo puede leer/escribir su propio documento,
    // identificado por su uid de Firebase Authentication.
    match /profes/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Contenido editable de cada juego (preguntas, rondas, configuración...),
      // un documento por juego, para que sincronice entre dispositivos.
      match /datosJuegos/{gameId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
